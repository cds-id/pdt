    "@commitlint/cz-commitlint": "^19.6.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.17.11",
    "@types/react": "^18.3.18",

    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.138",
    "ansi-to-react": "^6.2.6",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",

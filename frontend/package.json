{
  "name": "vite-tailwind-boilerplate",
  "description": "Boilerplate Projects",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Indra Gunanda",
    "email": "indra.gunanda@mail.com",
    "url": "https://github.com/cds-id"
  },
  "bugs": {
    "url": "https://github.com/cds-id/vite-tailwind-boilerplate/issues",
    "email": "indra.gunanda@mail.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --max-warnings=0 --fix",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepare": "husky",
    "commit": "git add . && cz",
    "push": "git push --follow-tags origin HEAD",
    "release": "release-it",
    "setup": "node template-setup.js",
    "setup:project": "node scripts/setup-project.js",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "requireCleanWorkingDir": false
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    }
  },
  "dependencies": {

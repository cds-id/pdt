    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-jsx-parser": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0",
